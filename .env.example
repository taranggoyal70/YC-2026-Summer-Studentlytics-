# Public frontend API base URL.
# Local development defaults to http://localhost:8000 when this is omitted.
# Production must point to the hosted/on-prem FastAPI backend, for example:
# VITE_API_ENDPOINT=https://api.yourdomain.edu
VITE_API_ENDPOINT=

# Optional external AI analytics assistant endpoint.
# If omitted, the teacher assistant answers from local roster analytics.
VITE_AI_CHAT_API_URL=

# Clerk authentication. The publishable key is intentionally public in Vite.
VITE_CLERK_PUBLISHABLE_KEY=

# Backend-only. Clerk JWT verification.
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=
CLERK_SECRET_KEY=

# Backend-only. Comma-separated allowed browser origins for CORS.
# Example: FRONTEND_ORIGINS=https://studentlytics.vercel.app,https://studentlytics.yourdomain.edu
FRONTEND_ORIGINS=

# Backend-only. Set to production to enforce deployment-only controls.
ENVIRONMENT=development
